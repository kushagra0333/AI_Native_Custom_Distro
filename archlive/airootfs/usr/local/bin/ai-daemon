#!/usr/bin/env python3
"""Launcher for the AI daemon inside the live environment."""

from __future__ import annotations

import os
import sys


INSTALL_ROOT = os.environ.get("AI_OS_INSTALL_ROOT", "/opt/ai-os")

if INSTALL_ROOT not in sys.path:
    sys.path.insert(0, INSTALL_ROOT)

from ai_core.daemon.main import main


if __name__ == "__main__":
    main()
